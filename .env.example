# =========================================================
# Ghimtech / Durga OS — Environment Variables
# Copy to .env.local and fill in.
# Production domain: https://ghimtech.org
# =========================================================

# ---------- Database (Supabase Postgres) ----------
# Pooled connection — used by app runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma migrations (NOT pooled)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ---------- Supabase Auth ----------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# Optional new Supabase publishable key name; the app accepts either key.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Owner allowlist. This email can sign up without an invite code.
AUTH_ALLOWED_EMAIL="reyghim1093@gmail.com"

# Comma-separated team invite codes. Non-owner emails must enter one at /sign-up.
# Leave blank to disable team signup.
AUTH_TEAM_INVITE_CODES="change-this-team-code"

# ---------- Seed script ----------
# REQUIRED for `npm run db:seed`. Get this from Supabase Auth > Users
# after you've signed up.
SEED_AUTH_USER_ID="uuid-from-supabase-auth"
SEED_EMAIL="durga@rayhealthevv.com"
SEED_FIRST_NAME="Durga"
SEED_LAST_NAME="Ghimeray"

# ---------- Site ----------
# Used for absolute URLs in emails, OG tags, etc.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------- Optional: production rate-limiting upgrade ----------
# When traffic warrants, install @upstash/ratelimit + @upstash/redis
# and provide these. Current in-memory limiter works without them.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ---------- Optional: email (for contact form notifications) ----------
# RESEND_API_KEY=""
