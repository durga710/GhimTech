# =========================================================
# Ghimtech / Durga OS — Environment Variables
# Copy to .env.local and fill in.
# Production domain: https://ghimtech.org
# =========================================================

# ---------- Database (Supabase Postgres) ----------
# Pooled connection — used by app runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma migrations (NOT pooled)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ---------- Supabase (only needed if using storage/realtime features) ----------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # server-only, never expose

# ---------- Clerk Auth ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Webhook signing secret from Clerk dashboard → Webhooks → Endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# Route configuration (defaults are fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ---------- Seed script ----------
# REQUIRED for `npm run db:seed`. Get this from Clerk dashboard → Users
# after you've signed up. Looks like "user_2abc...".
SEED_CLERK_ID="user_..."
SEED_EMAIL="durga@rayhealthevv.com"
SEED_FIRST_NAME="Durga"
SEED_LAST_NAME="Ghimeray"

# ---------- Site ----------
# Used for absolute URLs in emails, OG tags, etc.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------- Optional: production rate-limiting upgrade ----------
# When traffic warrants, install @upstash/ratelimit + @upstash/redis
# and provide these. Current in-memory limiter works without them.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ---------- Optional: email (for contact form notifications) ----------
# RESEND_API_KEY=""
